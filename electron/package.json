{
  "name": "bakers-raid-monitor",
  "version": "1.1.0",
  "description": "Live monitor for thebakers.work raids",
  "main": "out/main/index-modular.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "node ../build.js"
  },
  "build": {
    "appId": "com.bakers.raid-monitor",
    "productName": "Bakers Raid Monitor",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "asar": false,
    "files": [
      "out/**/*",
      "!**/ffmpeg.dll",
      "!**/ffprobe.dll"
    ],
    "extraResources": [
      {
        "from": "../bakers_raids.py",
        "to": "bakers_raids.py"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    }
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0"
  },
  "dependencies": {
    "ico": "^0.3.3"
  }
}
